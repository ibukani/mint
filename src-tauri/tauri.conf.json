{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mint",
  "version": "0.1.0",
  "identifier": "com.ibuibu.mint",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mint",
        "width": 900,
        "height": 650,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "maximizable": false
      },
      {
        "label": "clock",
        "title": "Clock Overlay",
        "width": 420,
        "height": 168,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "focusable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
